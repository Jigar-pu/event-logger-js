{
  "name": "multi-db-event-logger",
  "version": "1.0.0",
  "description": "A flexible event logger with MongoDB and PostgreSQL support, featuring AES-256-GCM encryption.",
  "author": "Jigar Suthar",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "event-logger",
    "event-tracker",
    "event-logging",
    "mongodb",
    "postgresql",
    "postgres",
    "encryption",
    "activity-logger",
    "activity-tracker",
    "multi-db-event-logger"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "mongodb": ">=6.0.0",
    "pg": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "mongodb": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "@types/pg": "^8.11.0",
    "mongodb": "^6.20.0",
    "pg": "^8.13.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Jigar-pu/event-logger-js"
  }
}
